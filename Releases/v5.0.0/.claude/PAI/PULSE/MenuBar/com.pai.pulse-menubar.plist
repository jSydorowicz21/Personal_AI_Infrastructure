<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pai.pulse-menubar</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/Applications/PAI Pulse.app/Contents/MacOS/PAI Pulse</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PAI_PULSE_DIR</key>
        <string>__PAI_DIR__/PULSE</string>
        <key>PAI_DIR</key>
        <string>__PAI_DIR__</string>
        <key>PAI_DATA_DIR</key>
        <string>__PAI_DATA_DIR__</string>
    </dict>
    <key>StandardOutPath</key>
    <string>__PAI_DIR__/PULSE/logs/menubar-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__PAI_DIR__/PULSE/logs/menubar-stderr.log</string>
</dict>
</plist>
