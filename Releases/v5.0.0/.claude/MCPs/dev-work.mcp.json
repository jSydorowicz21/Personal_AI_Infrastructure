{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "startup_timeout_sec": 30,
      "tool_timeout_sec": 120
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "startup_timeout_sec": 30,
      "tool_timeout_sec": 120
    }
  }
}
